{
  "name": "kb-test-20260522",
  "description": "API test with qa config",
  "chunking": {
    "mode": "hybrid",
    "aiMode": "never"
  },
  "rule": {
    "maxChars": 1200,
    "minChars": 80,
    "overlap": 80,
    "plainSeparators": ["\n\n", "\n"],
    "markdownSeparators": ["\n## ", "\n\n", "\n"],
    "sentenceBoundaryFallback": true
  },
  "quality": {
    "scoreThreshold": 70
  },
  "ai": {
    "chunkModel": "qwen-plus",
    "maxCallsPerDoc": 1,
    "maxInputTokens": 8000,
    "retryOnParseError": 1
  },
  "embedding": {
    "model": "text-embedding-v3"
  },
  "retrieval": {
    "topK": 3,
    "scoreThreshold": 0.5
  },
  "qa": {
    "scheme": 1,
    "rewriteMinScore": 0.35,
    "maxRewriteQueries": 2,
    "maxLlmCalls": 2,
    "maxSearchRounds": 2,
    "agentMaxIterations": 3,
    "agentMaxToolCallsPerRound": 1,
    "agentAllowRelaxThreshold": true
  }
}
